{
  "name": "beautiful-qr-code",
  "version": "1.0.10",
  "description": "Beautiful, customizable QR code generator with support for rounded corners, custom colors, and logos",
  "keywords": [
    "beautiful",
    "canvas",
    "customizable",
    "generator",
    "logo",
    "qr",
    "qr-code",
    "qrcode",
    "rounded",
    "styling",
    "svg"
  ],
  "homepage": "https://github.com/mblode/beautiful-qr-code#readme",
  "bugs": {
    "url": "https://github.com/mblode/beautiful-qr-code/issues"
  },
  "license": "MIT",
  "author": "Matthew Blode <m@mblode.com> (https://mblode.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mblode/beautiful-qr-code.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "check-types": "tsc --noEmit",
    "lint": "ultracite check",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.5",
    "typescript": "7.0.2",
    "ultracite": "7.9.3",
    "vitest": "^4.1.10"
  }
}
