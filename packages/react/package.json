{
  "name": "@beautiful-qr-code/react",
  "version": "1.0.10",
  "description": "React component for beautiful-qr-code",
  "keywords": [
    "beautiful",
    "component",
    "qr",
    "qr-code",
    "qrcode",
    "react"
  ],
  "homepage": "https://github.com/mblode/beautiful-qr-code#readme",
  "bugs": {
    "url": "https://github.com/mblode/beautiful-qr-code/issues"
  },
  "license": "MIT",
  "author": "Matthew Blode <m@mblode.com> (https://mblode.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mblode/beautiful-qr-code.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "lint": "ultracite check",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "beautiful-qr-code": "^1.0.10"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.5",
    "typescript": "7.0.2",
    "ultracite": "7.9.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
