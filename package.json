{
  "name": "beautiful-qr-code-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Beautiful QR code generator - Monorepo",
  "license": "MIT",
  "author": "Matthew Blode <m@mblode.com> (https://mblode.com)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "build:core": "turbo build --filter=beautiful-qr-code",
    "build:react": "turbo build --filter=@beautiful-qr-code/react",
    "build:cli": "turbo build --filter=@beautiful-qr-code/cli",
    "test": "turbo test",
    "test:core": "turbo test --filter=beautiful-qr-code",
    "check-types": "turbo check-types",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@beautiful-qr-code/web",
    "clean": "turbo clean && rm -rf node_modules/.cache/turbo",
    "release:publish": "npm run build --workspace=beautiful-qr-code --workspace=@beautiful-qr-code/react --workspace=@beautiful-qr-code/cli && npx changeset publish",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "typescript": "7.0.2",
    "ultracite": "7.9.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@10.9.2"
}
